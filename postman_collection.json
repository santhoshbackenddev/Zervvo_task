{
  "info": {
    "name": "Backend Task API",
    "description": "Postman collection for the Express, Prisma, PostgreSQL, Redis, JWT, and upload backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/register"
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        }
      ]
    },
    {
      "name": "Authors",
      "item": [
        {
          "name": "Get Authors",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/authors"
          }
        },
        {
          "name": "Get Author By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/authors/1"
          }
        },
        {
          "name": "Create Author",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Austen\",\n  \"email\": \"jane.austen@example.com\"\n}"
            },
            "url": "{{baseUrl}}/authors"
          }
        },
        {
          "name": "Update Author",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Austen Updated\"\n}"
            },
            "url": "{{baseUrl}}/authors/1"
          }
        },
        {
          "name": "Delete Author",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/authors/1"
          }
        }
      ]
    },
    {
      "name": "Books",
      "item": [
        {
          "name": "Get Books",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books"
          }
        },
        {
          "name": "Get Book By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/books/1"
          }
        },
        {
          "name": "Create Book",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Pride and Prejudice\",\n  \"description\": \"A classic novel of manners.\",\n  \"price\": 19.99,\n  \"authorId\": 1\n}"
            },
            "url": "{{baseUrl}}/books"
          }
        },
        {
          "name": "Update Book",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 21.99\n}"
            },
            "url": "{{baseUrl}}/books/1"
          }
        },
        {
          "name": "Delete Book",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/books/1"
          }
        }
      ]
    },
    {
      "name": "Upload Image",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "image",
              "type": "file",
              "src": []
            }
          ]
        },
        "url": "{{baseUrl}}/upload"
      }
    }
  ]
}
